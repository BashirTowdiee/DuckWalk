{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run DuckWalk Extension",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "duckWalk: build extension",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension",
        "${workspaceFolder}"
      ]
    }
  ]
}
