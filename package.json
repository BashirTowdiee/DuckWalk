{
  "name": "duckwalk",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/BashirTowdiee/DuckWalk.git"
  },
  "homepage": "https://github.com/BashirTowdiee/DuckWalk#readme",
  "bugs": {
    "url": "https://github.com/BashirTowdiee/DuckWalk/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "plugin:bump": "node scripts/plugin-bump.mjs",
    "plugin:refresh": "node scripts/plugin-refresh.mjs",
    "release:artifacts": "node scripts/release-artifacts.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:publish": "node scripts/release-publish.mjs",
    "release:version": "node scripts/release-version.mjs",
    "test": "vitest run",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.29.0",
    "globals": "^15.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.34.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
